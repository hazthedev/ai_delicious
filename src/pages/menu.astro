---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import MenuTabs from '../components/MenuTabs';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import site from '../data/site.json';
---

<BaseLayout
  title={`Menu | ${site.name} | ${site.nameZh}`}
  description="Explore our menu — Western mains, pasta, rice bowls, signature waffles & desserts. Dine-in & delivery in Setapak."
>
  <Navbar client:load transition:persist />

  <!-- Menu Hero -->
  <section class="relative pt-32 pb-20 md:pt-44 md:pb-28 bg-charcoal overflow-hidden">
    {/* Background texture */}
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, #FAF6F0 1px, transparent 0); background-size: 32px 32px;" />
    <div class="absolute top-0 right-0 w-[32rem] h-[32rem] bg-gold/4 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2" />
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-gold/3 rounded-full blur-3xl -translate-x-1/3 translate-y-1/3" />

    <div class="relative max-w-7xl mx-auto px-5 md:px-8">
      <div class="max-w-2xl">
        <p class="overline mb-6">Our Menu</p>
        <h1 class="font-display text-cream text-[2rem] md:text-5xl lg:text-6xl leading-[1.05] tracking-tight mb-6" style="font-variation-settings: 'opsz' 60;">
          Fresh, made-to-order,<br />
          <span class="text-gold">every single day.</span>
        </h1>
        <p class="text-cream/40 text-base md:text-lg max-w-md leading-relaxed">
          Every dish crafted with care. From hearty mains to indulgent waffles — there is something for everyone at the table.
        </p>
      </div>
    </div>
  </section>

  <MenuTabs client:only="react" />

  <!-- Order CTA -->
  <section class="py-16 md:py-24 bg-cream-dark">
    <div class="max-w-3xl mx-auto px-5 md:px-8 text-center">
      <p class="overline mb-5">Hungry?</p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1] tracking-tight mb-5" style="font-variation-settings: 'opsz' 40;">
        Ready to order?
      </h2>
      <p class="text-taupe mb-10 max-w-md mx-auto leading-relaxed">
        Chat with us on WhatsApp for the fastest response, or order through your favourite delivery app.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent("Hi! I'd like to place an order.")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-elastic inline-flex items-center gap-2.5 px-8 py-4 bg-[#25D366] text-white font-semibold text-sm rounded-full hover:shadow-lg hover:shadow-[#25D366]/25"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Order via WhatsApp
        </a>
        <a
          href={site.delivery.foodpanda}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-elastic inline-flex items-center gap-2 px-7 py-3.5 border border-charcoal/10 text-charcoal font-medium text-sm rounded-full hover:border-charcoal/30 transition-colors duration-300"
        >
          FoodPanda
        </a>
        <a
          href={site.delivery.grabfood}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-elastic inline-flex items-center gap-2 px-7 py-3.5 border border-charcoal/10 text-charcoal font-medium text-sm rounded-full hover:border-charcoal/30 transition-colors duration-300"
        >
          GrabFood
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
