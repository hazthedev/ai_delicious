---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import ContactForm from '../components/ContactForm';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import site from '../data/site.json';

const spaceIcons = [
  {
    label: 'Dining Area',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-8 h-8"><path d="M20 10c0 4.4-3.6 8-8 8s-8-3.6-8-8 3.6-8 8-8 8 3.6 8 8z"/><path d="M12 14v4"/><path d="M8 18h8"/></svg>`,
  },
  {
    label: 'Storefront',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-8 h-8"><path d="M3 21h18"/><path d="M5 21V7l8-4 8 4v14"/><path d="M5 7h16"/><path d="M9 21v-6a2 2 0 012-2h2a2 2 0 012 2v6"/></svg>`,
  },
  {
    label: 'Exterior',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-8 h-8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
  },
];
---

<BaseLayout
  title={`About & Contact | ${site.name} | ${site.nameZh}`}
  description="Learn our story, visit our cozy space in Setapak, and get in touch. Ai Delicious Cafe — serving comfort food since 2019."
>
  <Navbar client:load transition:persist />

  <!-- About Hero -->
  <section class="relative pt-32 pb-20 md:pt-44 md:pb-28 bg-charcoal overflow-hidden">
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, #FAF6F0 1px, transparent 0); background-size: 32px 32px;" />
    <div class="absolute bottom-0 left-0 w-[28rem] h-[28rem] bg-gold/4 rounded-full blur-3xl -translate-x-1/3 translate-y-1/3" />

    <div class="relative max-w-7xl mx-auto px-5 md:px-8">
      <div class="max-w-2xl">
        <p class="overline mb-6">Our Story</p>
        <h1 class="font-display text-cream text-[2rem] md:text-5xl lg:text-6xl leading-[1.05] tracking-tight mb-6" style="font-variation-settings: 'opsz' 60;">
          Great food should not<br />
          feel <span class="text-gold">rushed.</span>
        </h1>
        <p class="text-cream/40 text-base md:text-lg max-w-md leading-relaxed">
          Pull back the curtain, take a seat, and stay a while. We have been here since 2019, and we are not going anywhere.
        </p>
      </div>
    </div>
  </section>

  <!-- Story section -->
  <section class="py-16 md:py-28 lg:py-36 bg-cream">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-20 items-center">
        <!-- Text -->
        <div class="lg:col-span-5" data-reveal="left">
          <p class="overline mb-6">Since 2019</p>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1] tracking-tight mb-10" style="font-variation-settings: 'opsz' 48;">
            A quiet favourite<br />in Setapak.
          </h2>
          <div class="space-y-6 text-taupe leading-[1.75] text-[15px]">
            <p>
              We opened in 2019 with a simple idea: great food, a cosy space, and no rush.
              In a neighbourhood buzzing with options, we wanted to be the place where you
              actually slow down — where a meal feels like a moment, not a transaction.
            </p>
            <p>
              Our kitchen blends Western comfort food with Asian soul. From our signature
              chicken chop to handmade waffles, every dish is made to order with ingredients
              we are proud of. We do not cut corners, and we do not microwave.
            </p>
            <p>
              Years later, we are still here — still cooking, still growing, still grateful.
              Whether you are a regular or walking in for the first time, we want you to feel
              like you belong. That is the whole point.
            </p>
          </div>

          {/* Pull quote */}
          <div class="mt-12 pt-8 border-t border-charcoal/8">
            <p class="font-display text-2xl md:text-3xl text-charcoal leading-snug tracking-tight" style="font-variation-settings: 'opsz' 32;">
              "We do not just serve food. We serve <span class="text-gold">the feeling of being home.</span>"
            </p>
          </div>
        </div>

        <!-- Image placeholder -->
        <div class="lg:col-span-7 relative group" data-reveal="right">
          <div class="rounded-2xl overflow-hidden aspect-[16/10] lg:aspect-[4/5] border border-charcoal/5 bg-gradient-to-br from-cream-dark to-cream flex items-center justify-center">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(43,36,32,0.04)_1px,transparent_0)] bg-[length:24px_24px]" />
            <div class="relative flex h-16 w-16 md:h-24 md:w-24 items-center justify-center rounded-2xl md:rounded-3xl bg-surface text-gold/60 shadow-sm ring-1 ring-charcoal/5">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-8 h-8 md:w-12 md:h-12">
                <path d="M12 22v-8"/><path d="M12 14c-2-2-4-5-4-8a4 4 0 018 0c0 3-2 6-4 8z"/><path d="M12 14c2-2 4-5 4-8a4 4 0 00-8 0c0 3 2 6 4 8z"/>
              </svg>
            </div>
          </div>
          <div class="absolute -bottom-5 -right-5 w-32 h-32 border border-gold/15 rounded-2xl -z-10 hidden md:block" />
          <div class="absolute -top-5 -left-5 w-20 h-20 border border-gold/10 rounded-xl -z-10 hidden md:block" />
        </div>
      </div>
    </div>
  </section>

  <!-- The Space gallery — icon placeholders -->
  <section class="py-16 md:py-28 lg:py-36 bg-surface overflow-hidden">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="text-center mb-16 md:mb-20" data-reveal="up">
        <p class="overline mb-5">The Space</p>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1] tracking-tight" style="font-variation-settings: 'opsz' 48;">
          Bright, airy, and always<br /><span class="text-gold">welcoming.</span>
        </h2>
      </div>

      <div class="grid grid-cols-3 gap-3 md:gap-5">
        {spaceIcons.map((space, i) => (
          <div class="group rounded-xl md:rounded-2xl overflow-hidden aspect-square border border-charcoal/5 bg-gradient-to-br from-cream-dark to-cream flex flex-col items-center justify-center cursor-default" data-reveal="fade" data-reveal-delay={String(i + 1)}>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(43,36,32,0.03)_1px,transparent_0)] bg-[length:20px_20px] md:bg-[length:24px_24px]" />
            <div class="relative flex h-10 w-10 md:h-16 md:w-16 items-center justify-center rounded-lg md:rounded-2xl bg-surface text-gold/60 shadow-sm ring-1 ring-charcoal/5 group-hover:scale-105 transition-transform duration-500">
              <Fragment set:html={space.icon} />
            </div>
            <span class="relative mt-2 md:mt-4 text-[9px] md:text-[10px] font-medium uppercase tracking-[0.15em] md:tracking-[0.2em] text-taupe">{space.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Visit Us + Contact Form -->
  <section class="py-16 md:py-28 lg:py-36 bg-cream">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-start">
        {/* Map + Details */}
        <div>
          <p class="overline mb-6">Find Us</p>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1] tracking-tight mb-10" style="font-variation-settings: 'opsz' 48;">
            Come say<br /><span class="text-gold">hello.</span>
          </h2>

          {/* Map */}
          <div class="rounded-2xl overflow-hidden aspect-video mb-10 bg-cream-dark border border-charcoal/5 relative">
            <iframe
              src={site.maps.embed}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ai Delicious Cafe location"
              class="absolute inset-0 w-full h-full"
            />
          </div>

          {/* Details */}
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-gold mt-0.5 flex-shrink-0"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <p class="text-sm text-charcoal leading-relaxed">{site.address}</p>
            </div>
            <div class="flex items-start gap-4">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-gold mt-0.5 flex-shrink-0"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div class="text-sm text-charcoal">
                <p>Mon – Fri: 10:00 AM – 10:00 PM</p>
                <p>Sat – Sun: 9:00 AM – 10:30 PM</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-gold flex-shrink-0"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              <a href={`tel:${site.phone}`} class="text-sm text-charcoal hover:text-gold transition-colors duration-300">{site.phone}</a>
            </div>
          </div>

          <div class="flex gap-3 mt-10">
            <a
              href={site.maps.directions}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-elastic inline-flex items-center gap-2 px-7 py-3.5 bg-charcoal text-cream font-semibold text-sm rounded-full hover:shadow-lg hover:shadow-charcoal/15"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
              Get Directions
            </a>
            <a
              href={`https://wa.me/${site.whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-elastic inline-flex items-center gap-2 px-7 py-3.5 border border-charcoal/10 text-charcoal font-medium text-sm rounded-full hover:border-gold hover:text-gold transition-colors duration-300"
            >
              WhatsApp
            </a>
          </div>
        </div>

        {/* Contact Form */}
        <div>
          <p class="overline mb-6">Get in Touch</p>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1] tracking-tight mb-10" style="font-variation-settings: 'opsz' 48;">
            Drop us a<br /><span class="text-gold">message.</span>
          </h2>
          <ContactForm client:only="react" />
        </div>
      </div>
    </div>
  </section>

  <!-- Social links -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
      <p class="overline mb-10">Stay Connected</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href={site.socials.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="social-hover group flex items-center gap-3 px-7 py-5 rounded-2xl border border-charcoal/5 bg-surface hover:border-gold/25 hover:shadow-lg hover:shadow-gold/5"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-taupe group-hover:text-gold transition-colors duration-300">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
          <span class="font-medium text-charcoal text-sm">Instagram</span>
        </a>
        <a
          href={site.socials.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="social-hover group flex items-center gap-3 px-7 py-5 rounded-2xl border border-charcoal/5 bg-surface hover:border-gold/25 hover:shadow-lg hover:shadow-gold/5"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-taupe group-hover:text-gold transition-colors duration-300">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
          </svg>
          <span class="font-medium text-charcoal text-sm">Facebook</span>
        </a>
        <a
          href={site.socials.tiktok}
          target="_blank"
          rel="noopener noreferrer"
          class="social-hover group flex items-center gap-3 px-7 py-5 rounded-2xl border border-charcoal/5 bg-surface hover:border-gold/25 hover:shadow-lg hover:shadow-gold/5"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-taupe group-hover:text-gold transition-colors duration-300">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13a8.26 8.26 0 005.58 2.16V11.7a4.82 4.82 0 01-3.58-1.59V6.69h3.58z"/>
          </svg>
          <span class="font-medium text-charcoal text-sm">TikTok</span>
        </a>
      </div>
      <p class="text-taupe text-sm mt-8 max-w-sm mx-auto leading-relaxed">
        Follow us for daily specials, behind-the-scenes, and the occasional waffle that looks too good to eat.
      </p>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
