---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import ContactForm from '../components/ContactForm';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import site from '../data/site.json';
---

<BaseLayout
  title={`About & Contact | ${site.name} | ${site.nameZh}`}
  description="Learn our story, visit our cozy space in Setapak, and get in touch. Ai Delicious Cafe — serving comfort food since 2019."
>
  <Navbar client:only="react" transition:persist />

  <!-- About Hero -->
  <section class="relative pt-28 pb-16 md:pt-36 md:pb-24 bg-charcoal overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #FAF6F0 1px, transparent 0); background-size: 32px 32px;" />
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-gold/5 rounded-full blur-3xl -translate-x-1/3 translate-y-1/3" />

    <div class="relative max-w-7xl mx-auto px-5 md:px-8 text-center">
      <p class="text-gold font-medium text-sm tracking-[0.2em] uppercase mb-4">Our Story</p>
      <h1 class="font-display text-cream text-4xl md:text-6xl leading-tight mb-4" style="font-variation-settings: 'opsz' 60;">
        Great food shouldn't<br class="hidden sm:block" />
        feel <span class="text-gold">rushed</span>.
      </h1>
      <p class="text-cream/50 text-base md:text-lg max-w-lg mx-auto">
        Pull back the curtain, take a seat, and stay a while.
      </p>
    </div>
  </section>

  <!-- Story section -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-20 items-center">
        <!-- Text -->
        <div data-reveal="left">
          <p class="text-gold font-medium text-sm tracking-[0.2em] uppercase mb-4">Since 2019</p>
          <h2 class="font-display text-3xl md:text-4xl text-charcoal leading-snug mb-8" style="font-variation-settings: 'opsz' 36;">
            A quiet favorite in Setapak.
          </h2>
          <div class="space-y-5 text-taupe leading-relaxed">
            <p>
              We opened in 2019 with a simple idea: great food, a cozy space, and no rush.
              In a neighborhood buzzing with options, we wanted to be the place where you
              actually slow down — where a meal feels like a moment, not a transaction.
            </p>
            <p>
              Our kitchen blends Western comfort food with Asian soul. From our signature
              chicken chop to handmade waffles, every dish is made to order with ingredients
              we're proud of. We don't cut corners, and we don't microwave.
            </p>
            <p>
              Five years later, we're still here — still cooking, still growing, still grateful.
              Whether you're a regular or walking in for the first time, we want you to feel
              like you belong. That's the whole point.
            </p>
          </div>
        </div>

        <!-- Image -->
        <div class="relative group" data-reveal="right">
          <div class="rounded-2xl overflow-hidden aspect-[4/5]">
            <img
              src="/images/interior/greenery-ceiling.jpg"
              alt="Greenery ceiling at Ai Delicious Cafe"
              class="w-full h-full object-cover gallery-img"
            />
          </div>
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-2 border-gold/20 rounded-2xl -z-10" />
        </div>
      </div>
    </div>
  </section>

  <!-- The Space gallery — 3 unique images only -->
  <section class="py-20 md:py-28 bg-surface overflow-hidden">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="text-center mb-14" data-reveal="up">
        <p class="text-gold font-medium text-sm tracking-[0.2em] uppercase mb-3">The Space</p>
        <h2 class="font-display text-3xl md:text-4xl text-charcoal leading-tight" style="font-variation-settings: 'opsz' 36;">
          Bright, airy, and always welcoming.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="group rounded-xl overflow-hidden aspect-[3/4] md:aspect-[4/5] cursor-pointer" data-reveal="fade" data-reveal-delay="1">
          <img src="/images/interior/dining-area.jpg" alt="Wide view of the dining area" class="w-full h-full object-cover gallery-img" loading="lazy" />
        </div>
        <div class="group rounded-xl overflow-hidden aspect-[3/4] md:aspect-[4/5] cursor-pointer" data-reveal="fade" data-reveal-delay="2">
          <img src="/images/interior/storefront.jpg" alt="Ai Delicious storefront and signage" class="w-full h-full object-cover gallery-img" loading="lazy" />
        </div>
        <div class="group rounded-xl overflow-hidden aspect-[3/4] md:aspect-[4/5] cursor-pointer" data-reveal="fade" data-reveal-delay="3">
          <img src="/images/interior/exterior.jpg" alt="Exterior view of the cafe" class="w-full h-full object-cover gallery-img" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Visit Us + Contact Form -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-start">
        <!-- Map + Details -->
        <div>
          <p class="text-gold font-medium text-sm tracking-[0.2em] uppercase mb-3">Find Us</p>
          <h2 class="font-display text-3xl md:text-4xl text-charcoal leading-snug mb-8" style="font-variation-settings: 'opsz' 36;">
            Come say hello.
          </h2>

          <!-- Map -->
          <div class="rounded-2xl overflow-hidden aspect-video mb-8 bg-cream-dark relative">
            <iframe
              src={site.maps.embed}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ai Delicious Cafe location"
              class="absolute inset-0 w-full h-full"
            />
          </div>

          <!-- Details -->
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-gold mt-0.5 flex-shrink-0"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <p class="text-sm text-charcoal leading-relaxed">{site.address}</p>
            </div>
            <div class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-gold mt-0.5 flex-shrink-0"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div class="text-sm text-charcoal">
                <p>Mon – Fri: 10:00 AM – 10:00 PM</p>
                <p>Sat – Sun: 9:00 AM – 10:30 PM</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-gold flex-shrink-0"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              <a href={`tel:${site.phone}`} class="text-sm text-charcoal hover:text-gold transition-colors duration-300">{site.phone}</a>
            </div>
          </div>

          <div class="flex gap-3 mt-8">
            <a
              href={site.maps.directions}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-elastic inline-flex items-center gap-2 px-6 py-3 bg-charcoal text-cream font-semibold text-sm rounded-full hover:shadow-lg hover:shadow-charcoal/20"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
              Get Directions
            </a>
            <a
              href={`https://wa.me/${site.whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-elastic inline-flex items-center gap-2 px-6 py-3 border border-charcoal/10 text-charcoal font-medium text-sm rounded-full hover:border-gold hover:text-gold"
            >
              WhatsApp
            </a>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <p class="text-gold font-medium text-sm tracking-[0.2em] uppercase mb-3">Get in Touch</p>
          <h2 class="font-display text-3xl md:text-4xl text-charcoal leading-snug mb-8" style="font-variation-settings: 'opsz' 36;">
            Drop us a message.
          </h2>
          <ContactForm client:only="react" />
        </div>
      </div>
    </div>
  </section>

  <!-- Social links -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
      <p class="text-taupe text-sm mb-6">Follow us for daily specials and behind-the-scenes</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href={site.socials.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="social-hover group flex items-center gap-3 px-6 py-4 rounded-2xl border border-charcoal/5 bg-surface hover:border-gold/30 hover:shadow-lg hover:shadow-gold/5"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-taupe group-hover:text-gold transition-colors duration-300">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
          <span class="font-medium text-charcoal text-sm">Instagram</span>
        </a>
        <a
          href={site.socials.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="social-hover group flex items-center gap-3 px-6 py-4 rounded-2xl border border-charcoal/5 bg-surface hover:border-gold/30 hover:shadow-lg hover:shadow-gold/5"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-taupe group-hover:text-gold transition-colors duration-300">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
          </svg>
          <span class="font-medium text-charcoal text-sm">Facebook</span>
        </a>
        <a
          href={site.socials.tiktok}
          target="_blank"
          rel="noopener noreferrer"
          class="social-hover group flex items-center gap-3 px-6 py-4 rounded-2xl border border-charcoal/5 bg-surface hover:border-gold/30 hover:shadow-lg hover:shadow-gold/5"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-taupe group-hover:text-gold transition-colors duration-300">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13a8.26 8.26 0 005.58 2.16V11.7a4.82 4.82 0 01-3.58-1.59V6.69h3.58z"/>
          </svg>
          <span class="font-medium text-charcoal text-sm">TikTok</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
