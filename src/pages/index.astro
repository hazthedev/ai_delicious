---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import HeroMotion from '../components/HeroMotion';
import SignatureDishes from '../sections/SignatureDishes.astro';
import Gallery from '../sections/Gallery.astro';
import ValueProps from '../sections/ValueProps.astro';
import Reviews from '../sections/Reviews.astro';
import LocationTeaser from '../sections/LocationTeaser.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---

<BaseLayout>
  <Navbar client:only="react" transition:persist />
  <HeroMotion client:only="react" />
  <SignatureDishes />
  <Gallery />
  <ValueProps />
  <Reviews />
  <LocationTeaser />
  <Footer />
  <WhatsAppFloat />
</BaseLayout>
