---
const props = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/></svg>`,
    title: 'Three Preparations',
    description: 'Fried in a flower. Steamed soft. Boiled tender. Same fillings — chicken, beef, lamb. One dumpling, three ways.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Since 2013',
    description: 'Over a decade of serving Setapak. A Chinese-Muslim family-run restaurant with a surau on premises. The regulars know.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M4 11h16"/><path d="M4 15h16"/><path d="M6 11V9a6 6 0 0 1 12 0v2"/></svg>`,
    title: 'Hand-Pulled Noodles',
    description: 'Fresh la mian, pulled to order. Braised chicken kuan xin noodles at RM9. A rarity in KL, made the northern Chinese way.',
  },
];
---

<section class="py-16 md:py-28 lg:py-36 bg-cream relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: radial-gradient(circle at 1px 1px, var(--color-charcoal) 1px, transparent 0); background-size: 48px 48px;" />

  <div class="relative max-w-7xl mx-auto px-5 md:px-8">
    {/* Header */}
    <div class="text-center max-w-xl mx-auto mb-12 md:mb-20" data-reveal="up">
      <p class="overline mb-5">Why We Are Different</p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1] tracking-tight" style="font-variation-settings: 'opsz' 48;">
        The details that<br /><span class="text-gold">matter most.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
      {props.map((prop, i) => (
        <div class="text-center md:text-left group" data-reveal="up" data-reveal-delay={String(i + 1)}>
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-gold/8 text-gold mb-6 group-hover:bg-gold group-hover:text-cream transition-all duration-500" set:html={prop.icon} />
          <h3 class="font-display text-xl md:text-2xl text-charcoal mb-4 tracking-tight" style="font-variation-settings: 'opsz' 24;">
            {prop.title}
          </h3>
          <p class="body-editorial text-sm md:text-[15px] leading-[1.7] max-w-xs mx-auto md:mx-0">
            {prop.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
