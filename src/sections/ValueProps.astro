---
const props = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Halal Muslim-Friendly',
    description: 'Every dish prepared with care. Bringing communities together, one meal at a time.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Since 2019',
    description: 'Five years of serving Setapak. Trusted by families, couples, and friends.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Dine-in & Delivery',
    description: 'Enjoy our cozy space or order from home. Available on FoodPanda & GrabFood.',
  },
];
---

<section class="py-20 md:py-28 bg-cream relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, var(--color-charcoal) 1px, transparent 0); background-size: 40px 40px;" />

  <div class="relative max-w-7xl mx-auto px-5 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {props.map((prop, i) => (
        <div class="text-center group" data-reveal="up" data-reveal-delay={String(i + 1)}>
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gold/10 text-gold mb-6 group-hover:bg-gold group-hover:text-cream transition-all duration-500" set:html={prop.icon} />
          <h3 class="font-display text-xl md:text-2xl text-charcoal mb-3" style="font-variation-settings: 'opsz' 24;">
            {prop.title}
          </h3>
          <p class="text-taupe text-sm md:text-base leading-relaxed max-w-xs mx-auto">
            {prop.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
