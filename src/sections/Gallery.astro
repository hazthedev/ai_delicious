---
const tiles = [
  {
    type: 'note',
    class: 'col-span-2 md:col-span-3 lg:col-span-4',
  },
  {
    type: 'image',
    label: 'Storefront',
    icon: 'store',
    class: 'col-span-1 md:col-span-3 lg:col-span-4',
  },
  {
    type: 'image',
    label: 'Greenery',
    icon: 'plant',
    class: 'col-span-1 md:col-span-3 lg:col-span-4 lg:row-span-2',
  },
  {
    type: 'image',
    label: 'Dining',
    icon: 'dining',
    class: 'col-span-1 md:col-span-4 lg:col-span-4',
  },
  {
    type: 'logo',
    class: 'col-span-1 md:col-span-4 lg:col-span-4',
  },
  {
    type: 'quote',
    class: 'col-span-1 md:col-span-3 lg:col-span-4',
  },
  {
    type: 'image',
    label: 'Exterior',
    icon: 'building',
    class: 'col-span-1 md:col-span-5 lg:col-span-4',
  },
  {
    type: 'cta',
    class: 'col-span-1 md:col-span-3 lg:col-span-4',
  },
  {
    type: 'hours',
    class: 'col-span-2 md:col-span-8 lg:col-span-12',
  },
];
---

<section class="py-16 md:py-28 lg:py-36 bg-surface">
  <div class="max-w-7xl mx-auto px-5 md:px-8">
    {/* Header */}
    <div class="max-w-2xl mb-16 md:mb-24" data-reveal="up">
      <p class="overline mb-5">The Space</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-charcoal leading-[1.05] tracking-tight" style="font-variation-settings: 'opsz' 60;">
        Light, air, and<br />
        <span class="text-gold">greenery overhead.</span>
      </h2>
    </div>

    {/* Editorial Bento Grid */}
    <div class="rounded-[1.5rem] md:rounded-[2rem] bg-charcoal p-2.5 md:p-5 shadow-2xl shadow-charcoal/8" data-reveal="scale">
      <div class="grid grid-cols-2 md:grid-cols-8 lg:grid-cols-12 auto-rows-[120px] md:auto-rows-[180px] gap-2.5 md:gap-4">
        {tiles.map((tile, i) => (
          <div class={`relative overflow-hidden rounded-xl md:rounded-2xl ${tile.class}`} data-reveal="fade" data-reveal-delay={String((i % 5) + 1)}>
            {tile.type === 'image' && (
              <div class="absolute inset-0 flex flex-col items-center justify-center bg-gradient-to-br from-cream-dark to-cream">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(43,36,32,0.03)_1px,transparent_0)] bg-[length:20px_20px] md:bg-[length:24px_24px]" />
                <div class="relative flex h-12 w-12 md:h-16 md:w-16 items-center justify-center rounded-xl md:rounded-2xl bg-surface text-gold/60 shadow-sm ring-1 ring-charcoal/5">
                  {tile.icon === 'store' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-6 h-6 md:w-8 md:h-8"><path d="M3 21h18"/><path d="M5 21V7l8-4 8 4v14"/><path d="M5 7h16"/><path d="M9 21v-6a2 2 0 012-2h2a2 2 0 012 2v6"/></svg>}
                  {tile.icon === 'plant' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-6 h-6 md:w-8 md:h-8"><path d="M12 22v-8"/><path d="M12 14c-2-2-4-5-4-8a4 4 0 018 0c0 3-2 6-4 8z"/><path d="M12 14c2-2 4-5 4-8a4 4 0 00-8 0c0 3 2 6 4 8z"/></svg>}
                  {tile.icon === 'dining' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-6 h-6 md:w-8 md:h-8"><path d="M20 10c0 4.4-3.6 8-8 8s-8-3.6-8-8 3.6-8 8-8 8 3.6 8 8z"/><path d="M12 14v4"/><path d="M8 18h8"/></svg>}
                  {tile.icon === 'building' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-6 h-6 md:w-8 md:h-8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>}
                </div>
                <span class="mt-2 md:mt-3 text-[9px] md:text-[10px] font-medium uppercase tracking-[0.15em] md:tracking-[0.2em] text-taupe">{tile.label}</span>
              </div>
            )}

            {tile.type === 'note' && (
              <div class="flex h-full flex-col justify-between p-4 md:p-7 bg-cream">
                <div>
                  <p class="text-[9px] md:text-[10px] font-semibold uppercase tracking-[0.15em] md:tracking-[0.2em] text-sage mb-2 md:mb-3">Setapak Favourite</p>
                  <p class="text-xs md:text-sm font-medium leading-relaxed text-charcoal">
                    Cosy corners for long lunches, quick catch-ups, and slow evenings that stretch past dessert.
                  </p>
                </div>
                <p class="font-display text-xl md:text-3xl text-gold mt-3 md:mt-0" style="font-variation-settings: 'opsz' 36;">Since 2019</p>
              </div>
            )}

            {tile.type === 'logo' && (
              <div class="flex h-full flex-col items-center justify-center bg-surface px-3 md:px-6 text-center">
                <div class="mb-3 md:mb-5 grid grid-cols-3 gap-1.5 md:gap-2 text-gold">
                  {[...Array(9)].map((_, dot) => (
                    <span class={`block h-2 w-2 md:h-3 md:w-3 rounded-full ${dot % 2 === 0 ? 'bg-gold' : 'bg-sage'}`} />
                  ))}
                </div>
                <span class="font-zh text-2xl md:text-4xl leading-none text-gold">爱品味</span>
                <span class="mt-1.5 md:mt-3 font-display text-sm md:text-xl text-charcoal tracking-wide" style="font-variation-settings: 'opsz' 28;">
                  Ai Delicious
                </span>
              </div>
            )}

            {tile.type === 'quote' && (
              <div class="flex h-full items-center justify-center bg-gold px-3 md:px-6 text-center text-cream">
                <p class="font-display text-base md:text-2xl lg:text-3xl leading-snug" style="font-variation-settings: 'opsz' 36;">
                  Fresh plates.<br class="hidden md:block" /> Warm lights.<br class="hidden md:block" /> No rush.
                </p>
              </div>
            )}

            {tile.type === 'cta' && (
              <div class="flex h-full flex-col justify-between bg-gold p-4 md:p-7 text-cream">
                <p class="text-[9px] md:text-[10px] font-semibold uppercase tracking-[0.15em] md:tracking-[0.2em] text-cream/60">Visit Us</p>
                <div>
                  <p class="font-display text-sm md:text-xl lg:text-2xl leading-snug mb-1 md:mb-2">Come say hello.</p>
                  <p class="text-[10px] md:text-sm text-cream/70 leading-relaxed">Wangsa Maju, Setapak, KL</p>
                </div>
              </div>
            )}

            {tile.type === 'hours' && (
              <div class="flex h-full flex-col md:flex-row md:items-center md:justify-between bg-cream-dark p-4 md:px-8 md:py-6 gap-3 md:gap-0">
                <p class="text-[9px] md:text-[10px] font-semibold uppercase tracking-[0.15em] md:tracking-[0.2em] text-sage md:w-28 flex-shrink-0">Opening Hours</p>
                <div class="flex gap-6 md:gap-12 text-xs md:text-sm font-medium text-charcoal">
                  <p>Mon – Fri <span class="text-taupe font-normal ml-1 md:ml-2">10:00 AM – 10:00 PM</span></p>
                  <p>Sat – Sun <span class="text-taupe font-normal ml-1 md:ml-2">9:00 AM – 10:30 PM</span></p>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
