---
const dishes = [
  {
    name: 'Fried Sam Xin Chicken Dumplings',
    description: '18 pieces deep-fried in a golden flower shape. Crispy edges, juicy centre. Our signature since 2013.',
    price: 'RM 18.00',
    tag: 'Signature 招牌',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-10 h-10 md:w-12 md:h-12"><circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/></svg>`,
  },
  {
    name: 'Steamed Lamb Gyoza',
    description: '16 pieces of soft, pillowy lamb dumplings. Steamed until translucent and tender.',
    price: 'RM 12.00',
    tag: 'Best Value',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-10 h-10 md:w-12 md:h-12"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>`,
  },
  {
    name: 'Braised Chicken Kuan Xin Noodles',
    description: 'Hand-pulled flat noodles in a rich braised chicken sauce. A PV128 favourite.',
    price: 'RM 9.00',
    tag: 'House Favourite',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-10 h-10 md:w-12 md:h-12"><path d="M4 11h16"/><path d="M4 15h16"/><path d="M6 11V9a6 6 0 0 1 12 0v2"/></svg>`,
  },
];
---

<section class="py-16 md:py-28 lg:py-36 bg-cream">
  <div class="max-w-7xl mx-auto px-5 md:px-8">
    {/* Header */}
    <div class="max-w-2xl mb-12 md:mb-20" data-reveal="up">
      <p class="overline mb-4 md:mb-5">Signature Favourites</p>
      <h2 class="font-display text-3xl md:text-5xl lg:text-6xl text-charcoal leading-[1.05] tracking-tight mb-4 md:mb-6" style="font-variation-settings: 'opsz' 60;">
        Three preparations.<br />
        <span class="text-gold">One dumpling.</span>
      </h2>
      <p class="body-editorial text-sm md:text-base max-w-md">
        Pan-fried in a flower. Steamed soft and pillowy. Boiled tender for soup. Same fillings — chicken, beef, lamb. Pick how you want them today.
      </p>
    </div>

    {/* Editorial Grid */}
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
      {/* Feature dish */}
      <a href="/menu" class="group md:col-span-7 relative rounded-2xl overflow-hidden cursor-pointer card-hover block bg-charcoal" data-reveal="scale" data-reveal-delay="1">
        <div class="aspect-[16/10] relative">
          <div class="absolute inset-0 flex items-center justify-center bg-charcoal">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(250,246,240,0.08)_1px,transparent_0)] bg-[length:28px_28px]" />
            <div class="absolute inset-x-0 top-0 h-24 md:h-32 bg-gradient-to-b from-gold/20 to-transparent" />
            <div class="relative flex h-16 w-16 md:h-24 md:w-24 items-center justify-center rounded-xl md:rounded-2xl bg-cream/8 text-gold/60 ring-1 ring-cream/10 transition-all duration-500 group-hover:bg-gold group-hover:text-cream group-hover:scale-105">
              <Fragment set:html={dishes[0].icon} />
            </div>
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
        </div>
        <div class="absolute top-4 left-4 md:top-5 md:left-5">
          <span class="px-2.5 py-1 md:px-3 md:py-1.5 bg-gold/90 text-cream text-[9px] md:text-[10px] font-semibold uppercase tracking-[0.15em] rounded-full backdrop-blur-sm">
            {dishes[0].tag}
          </span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-5 md:p-8">
          <div class="text-slide">
            <p class="text-cream/60 text-xs md:text-sm mb-1 md:mb-2">{dishes[0].price}</p>
            <h3 class="font-display text-cream text-lg md:text-2xl lg:text-3xl mb-1 md:mb-2" style="font-variation-settings: 'opsz' 32;">
              {dishes[0].name}
            </h3>
            <p class="text-cream/70 text-xs md:text-sm leading-relaxed max-w-sm hidden sm:block">
              {dishes[0].description}
            </p>
          </div>
        </div>
        <div class="absolute inset-0 rounded-2xl border-2 border-gold/0 group-hover:border-gold/25 transition-all duration-700 ease-[cubic-bezier(0.25,0.1,0.25,1)]" />
      </a>

      {/* Side dishes */}
      <div class="md:col-span-5 grid grid-cols-1 gap-4 md:gap-6">
        <a href="/menu" class="group relative rounded-2xl overflow-hidden cursor-pointer card-hover block bg-charcoal" data-reveal="scale" data-reveal-delay="2">
          <div class="aspect-[16/10] md:aspect-auto md:h-full relative">
            <div class="absolute inset-0 flex items-center justify-center bg-charcoal">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(250,246,240,0.08)_1px,transparent_0)] bg-[length:28px_28px]" />
              <div class="relative flex h-14 w-14 md:h-20 md:w-20 items-center justify-center rounded-xl md:rounded-2xl bg-cream/8 text-gold/60 ring-1 ring-cream/10 transition-all duration-500 group-hover:bg-gold group-hover:text-cream group-hover:scale-105">
                <Fragment set:html={dishes[1].icon} />
              </div>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
          </div>
          <div class="absolute top-4 left-4 md:top-5 md:left-5">
            <span class="px-2.5 py-1 md:px-3 md:py-1.5 bg-cream/90 text-charcoal text-[9px] md:text-[10px] font-semibold uppercase tracking-[0.15em] rounded-full backdrop-blur-sm">
              {dishes[1].tag}
            </span>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
            <div class="text-slide">
              <p class="text-cream/60 text-xs md:text-sm mb-1">{dishes[1].price}</p>
              <h3 class="font-display text-cream text-base md:text-xl lg:text-2xl" style="font-variation-settings: 'opsz' 28;">
                {dishes[1].name}
              </h3>
            </div>
          </div>
          <div class="absolute inset-0 rounded-2xl border-2 border-gold/0 group-hover:border-gold/25 transition-all duration-700 ease-[cubic-bezier(0.25,0.1,0.25,1)]" />
        </a>

        <a href="/menu" class="group relative rounded-2xl overflow-hidden cursor-pointer card-hover block bg-charcoal" data-reveal="scale" data-reveal-delay="3">
          <div class="aspect-[16/10] md:aspect-auto md:h-full relative">
            <div class="absolute inset-0 flex items-center justify-center bg-charcoal">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(250,246,240,0.08)_1px,transparent_0)] bg-[length:28px_28px]" />
              <div class="relative flex h-14 w-14 md:h-20 md:w-20 items-center justify-center rounded-xl md:rounded-2xl bg-cream/8 text-gold/60 ring-1 ring-cream/10 transition-all duration-500 group-hover:bg-gold group-hover:text-cream group-hover:scale-105">
                <Fragment set:html={dishes[2].icon} />
              </div>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
          </div>
          <div class="absolute top-4 left-4 md:top-5 md:left-5">
            <span class="px-2.5 py-1 md:px-3 md:py-1.5 bg-cream/90 text-charcoal text-[9px] md:text-[10px] font-semibold uppercase tracking-[0.15em] rounded-full backdrop-blur-sm">
              {dishes[2].tag}
            </span>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
            <div class="text-slide">
              <p class="text-cream/60 text-xs md:text-sm mb-1">{dishes[2].price}</p>
              <h3 class="font-display text-cream text-base md:text-xl lg:text-2xl" style="font-variation-settings: 'opsz' 28;">
                {dishes[2].name}
              </h3>
            </div>
          </div>
          <div class="absolute inset-0 rounded-2xl border-2 border-gold/0 group-hover:border-gold/25 transition-all duration-700 ease-[cubic-bezier(0.25,0.1,0.25,1)]" />
        </a>
      </div>
    </div>

    {/* Bottom link */}
    <div class="mt-10 md:mt-14 text-center" data-reveal="up">
      <a
        href="/menu"
        class="inline-flex items-center gap-2 text-charcoal font-medium text-sm tracking-wide hover:text-gold transition-colors duration-300 group"
      >
        <span class="relative">
          View full menu
          <span class="absolute left-0 -bottom-0.5 w-full h-px bg-current transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
        </span>
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
