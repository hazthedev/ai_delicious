---
import site from '../data/site.json';
import { Instagram, Facebook, Phone, Mail, MapPin, Clock } from 'lucide-react';
---

<footer class="bg-charcoal text-cream/80">
  <!-- Decorative gold line -->
  <div class="h-px bg-gradient-to-r from-transparent via-gold to-transparent" />

  <div class="max-w-7xl mx-auto px-5 md:px-8 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <!-- Brand -->
      <div>
        <span class="font-zh text-gold text-3xl block mb-3">爱品味</span>
        <p class="font-display text-lg text-cream mb-4">Ai Delicious Cafe</p>
        <p class="text-cream/50 text-sm leading-relaxed max-w-xs">
          Made with love in Setapak. See you soon.
        </p>
        <div class="flex items-center gap-4 mt-6">
          <a
            href={site.socials.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Follow us on Instagram"
            class="social-hover w-10 h-10 rounded-full border border-cream/20 flex items-center justify-center text-cream/60 hover:border-gold hover:text-gold hover:bg-gold/10"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5">
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <circle cx="12" cy="12" r="5" />
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <a
            href={site.socials.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Follow us on Facebook"
            class="social-hover w-10 h-10 rounded-full border border-cream/20 flex items-center justify-center text-cream/60 hover:border-gold hover:text-gold hover:bg-gold/10"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
            </svg>
          </a>
          <a
            href={site.socials.tiktok}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Follow us on TikTok"
            class="social-hover w-10 h-10 rounded-full border border-cream/20 flex items-center justify-center text-cream/60 hover:border-gold hover:text-gold hover:bg-gold/10"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13a8.26 8.26 0 005.58 2.16V11.7a4.82 4.82 0 01-3.58-1.59V6.69h3.58z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Hours -->
      <div>
        <h4 class="font-display text-cream text-lg mb-5 flex items-center gap-2">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-gold"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Opening Hours
        </h4>
        <dl class="space-y-3 text-sm">
          <div class="flex items-baseline gap-3">
            <dt class="text-cream/50 whitespace-nowrap">Mon – Fri</dt>
            <dd class="whitespace-nowrap">10:00 AM – 10:00 PM</dd>
          </div>
          <div class="flex items-baseline gap-3">
            <dt class="text-cream/50 whitespace-nowrap">Sat – Sun</dt>
            <dd class="whitespace-nowrap">9:00 AM – 10:30 PM</dd>
          </div>
        </dl>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display text-cream text-lg mb-5 flex items-center gap-2">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-gold"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Find Us
        </h4>
        <address class="not-italic text-sm space-y-3">
          <p class="leading-relaxed">{site.address}</p>
          <a href={`tel:${site.phone}`} class="flex items-center gap-2 text-cream/60 hover:text-gold transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            {site.phone}
          </a>
          <a href={`mailto:${site.email}`} class="flex items-center gap-2 text-cream/60 hover:text-gold transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,4 12,13 2,4"/></svg>
            {site.email}
          </a>
        </address>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-cream/10 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-cream/30">
      <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
      <p>
        <a href={site.delivery.foodpanda} target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors">FoodPanda</a>
        <span class="mx-2">·</span>
        <a href={site.delivery.grabfood} target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors">GrabFood</a>
      </p>
    </div>
  </div>
</footer>
