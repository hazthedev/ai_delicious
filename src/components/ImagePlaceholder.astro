---
export interface Props {
  icon?: string;
  label?: string;
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { icon, label, class: className = '', size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'w-10 h-10',
  md: 'w-16 h-16',
  lg: 'w-24 h-24',
};

const iconSizes = {
  sm: 'w-5 h-5',
  md: 'w-7 h-7',
  lg: 'w-10 h-10',
};
---

<div class={`flex flex-col items-center justify-center gap-3 ${className}`}>
  <div class={`${sizeClasses[size]} rounded-2xl bg-gold/8 border border-gold/15 flex items-center justify-center`}>
    {icon ? (
      <Fragment set:html={icon} />
    ) : (
      <svg class={`${iconSizes[size]} text-gold/60`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="3"/>
        <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" stroke="none"/>
        <path d="M21 15l-5-5-4 4-3-3-6 6"/>
      </svg>
    )}
  </div>
  {label && <span class="text-[11px] text-taupe tracking-wide">{label}</span>}
</div>
